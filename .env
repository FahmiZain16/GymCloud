# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gymcloud_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Server Configuration
